    "def run_code(state: GameState):\n",
    "    print(\"\\n===== CODE EXECUTION =====\")\n",
    "    choice = input(\"Run the generated game? (y/n): \").strip().lower()\n",
    "    execution_result = \"\"\n",
    "    if choice == 'y':\n",
    "        try:\n",
    "            result = subprocess.run(\n",
    "                [\"python\", \"dino_runner.py\"],\n",
    "                capture_output=True,\n",
    "                text=True,\n",
    "                timeout=15\n",
    "            )\n",
    "            if result.returncode == 0:\n",
